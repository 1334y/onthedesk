{
  "productName": "Clawd",
  "version": "0.1.0",
  "identifier": "com.clawd.deskpet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clawd",
        "width": 227,
        "height": 210,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": true,
        "center": false,
        "x": 800,
        "y": 600,
        "shadow": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'unsafe-inline' 'self'; img-src 'self' data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  }
}
