{
  "$schema": "https://raw.githubusercontent.com/nicedoc/learn-tauri/refs/heads/main/.schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for Clawd",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:window:allow-start-dragging",
    "core:window:allow-set-position"
  ]
}
